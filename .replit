language="nodejs"
run="yarn start && pm2 save && pm2 logs"
entrypoint = "src/aurora.js"
hidden = [".config", "yarn.lock"]
modules = ["nodejs-20"]

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "yarn start"

[workflows.workflow.metadata]
outputType = "console"

[nix]
channel = "stable-25_05"

[[ports]]
localPort = 3000
externalPort = 80
